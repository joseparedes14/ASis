# ASis - AI Assistant Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Configuration
# =============================================================================
# Provider: "ollama", "openai", "anthropic"
LLM_PROVIDER=ollama
# Model name (depends on provider)
LLM_MODEL=llama3.1:8b
# Ollama base URL (only for ollama provider)
OLLAMA_BASE_URL=http://localhost:11434
# OpenAI API Key (only for openai provider)
# OPENAI_API_KEY=sk-...
# Anthropic API Key (only for anthropic provider)
# ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# Email Configuration (IMAP)
# =============================================================================
# EMAIL_IMAP_SERVER=imap.gmail.com
# EMAIL_IMAP_PORT=993
# EMAIL_ADDRESS=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password
# EMAIL_USE_SSL=true

# =============================================================================
# Email Configuration (OAuth2 - preferred)
# =============================================================================
# EMAIL_OAUTH_CLIENT_ID=
# EMAIL_OAUTH_CLIENT_SECRET=
# EMAIL_OAUTH_TOKEN_FILE=./data/oauth_token.json

# =============================================================================
# Email Configuration (SMTP - for sending)
# =============================================================================
# EMAIL_SMTP_SERVER=smtp.gmail.com
# EMAIL_SMTP_PORT=465
# EMAIL_OAUTH_CREDENTIALS_FILE=./credentials.json

# =============================================================================
# Storage Configuration
# =============================================================================
DATA_DIR=./data
DOWNLOADS_DIR=./data/downloads
ATTACHMENTS_DIR=./data/attachments

# =============================================================================
# Application Settings
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=./data/logs/asis.log
# Maximum conversation history length
MAX_HISTORY_LENGTH=50
# Require user confirmation for sensitive actions
REQUIRE_CONFIRMATION=true

# =============================================================================
# Security
# =============================================================================
# Comma-separated list of tools that require user confirmation
SENSITIVE_TOOLS=download_attachment,save_file,delete_email,organize_documents
